# 企业级 RAG 系统 - 环境变量配置
# ========================================
# 使用：复制为 .env，按实际修改；勿提交 .env
# 字段以 core/config.py 为唯一事实源
# ========================================

# =========================================
# 应用基础配置
# =========================================
APP_NAME=Enterprise RAG System
APP_VERSION=1.0.0
API_PREFIX=/api/v1
DEBUG=false
# 运行环境：development / production
ENVIRONMENT=production

# =========================================
# 服务器配置
# =========================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# =========================================
# PostgreSQL 关系数据库
# =========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=enterprise_rag

# =========================================
# Milvus 向量数据库
# =========================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_STANDARD=rag_standards
MILVUS_COLLECTION_PROJECT=rag_projects
MILVUS_COLLECTION_CONTRACT=rag_contracts
# 向量维度需与 Embedding 模型一致（bge-large-zh-v1.5 -> 1024）
VECTOR_DIM=1024
# 索引类型：IVF_FLAT / IVF_SQ8 / HNSW
MILVUS_INDEX_TYPE=IVF_FLAT
# 度量方式：IP / L2 / COSINE
MILVUS_METRIC_TYPE=IP

# =========================================
# Redis 缓存
# =========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# 缓存过期时间（秒），默认 6 小时
REDIS_CACHE_TTL=21600

# =========================================
# Neo4j 图数据库
# =========================================
# 本地: bolt://localhost:7687 ；Docker: bolt://neo4j:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_MAX_TRANSACTION_RETRY_TIME=30

# =========================================
# Embedding 向量化模型
# =========================================
# 单一事实源：BAAI/bge-large-zh-v1.5（维度 1024）
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
# 本地模型路径（可选）
EMBEDDING_MODEL_PATH=
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_LENGTH=512

# =========================================
# 文档处理
# =========================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
OCR_ENABLED=true
# OCR 语言：ch / en
OCR_LANGUAGE=ch
# 支持的文件类型（不含图片）
SUPPORTED_FILE_TYPES=.pdf,.docx,.doc,.txt

# =========================================
# 混合检索
# =========================================
# 三者之和应为 1.0
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.4
RERANK_WEIGHT=0.3
# 初始召回数量
RETRIEVAL_TOP_K=100
# 重排序后返回数量
RERANK_TOP_K=5
# 重排序模型
RERANK_MODEL_NAME=BAAI/bge-reranker-base

# =========================================
# LLM 大语言模型
# =========================================
LLM_MODEL_NAME=Qwen/Qwen-7B-Chat
# API 地址（OpenAI 兼容）：
# - 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# - 智谱 GLM: https://open.bigmodel.cn/api/paas/v4
# - 本地 vLLM: http://localhost:8000/v1
LLM_API_BASE=
LLM_API_KEY=your_api_key_here
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
# LoRA 微调（可选）
LORA_ENABLED=false
LORA_MODEL_PATH=

# =========================================
# 权限与安全
# =========================================
ENABLE_PERMISSION_CHECK=true
# 允许的跨域来源（JSON 数组）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# JWT 密钥（生产环境必须修改为强随机串）
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
# JWT 过期时间（分钟），默认 24 小时
JWT_EXPIRE_MINUTES=1440

# =========================================
# 日志
# =========================================
LOG_LEVEL=INFO
LOG_FILE_MAX_SIZE=100 MB
LOG_FILE_ROTATION=1 day
LOG_FILE_RETENTION=30 days

# =========================================
# 性能与监控
# =========================================
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=60
ENABLE_METRICS=true
ENABLE_QUERY_LOG=true
